# AIモデル・音声データ（大容量・機密。リポジトリに含めない）
/models/
*.gguf
*.bin
*.onnx
*.safetensors
*.wav
*.mp3
*.flac
*.m4a

# 環境・シークレット
.env
.env.*
*.local

# ログ・一時ファイル
*.log
/tmp/
/.tmp/

# OS
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# エディタ / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code（個人設定のみ無視。共有設定 settings.json はコミット可）
.claude/settings.local.json

# STTベンチ用の録音音声（個人の声・バイナリ。正解テキスト script*.txt は対象外）
/python/audio/*.wav

# UI起動スクリプトの実行時PIDファイル
/scripts/.synchroni-ui.pid
